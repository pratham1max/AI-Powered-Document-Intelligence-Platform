# ── AI ────────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-api-key

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MASTER_SECRET=replace-with-32-char-random-secret

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (local dev, zero config)
# For production: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_USER=docuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=docplatform

# ── Redis (optional for local dev) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Firebase Backend ─────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional: path to service account JSON (for production)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── Firebase Frontend ─────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Storage ───────────────────────────────────────────────────────────────────
ENCRYPTED_FILES_DIR=./encrypted_files

# ── pgvector (set to true only if PostgreSQL has pgvector installed) ──────────
USE_PGVECTOR=false
